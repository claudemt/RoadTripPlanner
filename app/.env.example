# Vite build variables. These values are bundled into the browser application.
VITE_SITE_NAME=山河路书

# Optional build-time fallback. The preferred production method is to save the
# AMap values from the application's configuration dialog into data/config/local.env.
VITE_AMAP_KEY=
VITE_AMAP_SECURITY_JS_CODE=

# Server runtime variables are process environment variables, not Vite values:
# Put production runtime values in /etc/roadplan/map.env, not in Vite files:
# AMAP_ROUTE_HOST=0.0.0.0
# AMAP_ROUTE_PORT=6137
# ROADTRIP_USER_EMAIL_HEADER=Remote-Email
# ROADTRIP_REQUIRE_USER_EMAIL=true
# ROADTRIP_REQUIRE_SUPABASE=true
# ROADTRIP_ADMIN_EMAILS=admin@map.bestapi.best
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# AMAP_KEY=
# AMAP_SECURITY_JS_CODE=
