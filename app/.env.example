# EdgeOne Pages build variables. These values are bundled into the browser app.
VITE_SITE_NAME=山河路书
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
VITE_SUPABASE_OIDC_PROVIDER=custom:cloud-iam
VITE_IDENTITY_LABEL=Cloud-IAM
VITE_IDENTITY_ACCOUNT_URL=https://auth.example.com/realms/roadtrip/account/

# Optional fallback only. In production, admin should maintain AMap keys in the website config page.
VITE_AMAP_KEY=
VITE_AMAP_SECURITY_JS_CODE=
